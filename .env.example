
# F1 Tracker 2026 - Environment Configuration Example

# MongoDB Connection
# local: mongodb://localhost:27017/f1tracker2026
MONGODB_URI=your_mongodb_uri_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Server Configuration
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:5000

# Admin Setup
ADMIN_SEED_KEY=your_admin_seed_key_here

# OAuth Credentials (Google & Discord)
# Follow the setup guides in the brain/ directory for more info
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# LiveKit SFU Credentials
VITE_LIVEKIT_URL=your_livekit_url_here
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here